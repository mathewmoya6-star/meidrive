# ====================================================
# BACKEND .gitignore - MEI DRIVE AFRICA (Node.js)
# ====================================================
# ⚠️ CRITICAL: This protects your M-Pesa production keys!
# ====================================================

# Dependencies
node_modules/
package-lock.json
yarn.lock

# ====================================================
# SECRETS - NEVER COMMIT THESE! 🔒
# ====================================================
.env                    # M-Pesa keys, Supabase keys
.env.local
.env.production
.env.development
*.env
*.env.*

# ====================================================
# Logs
# ====================================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/
*.pid
*.seed
*.pid.lock

# ====================================================
# OS files
# ====================================================
.DS_Store
Thumbs.db
desktop.ini
*.dll
*.exe

# ====================================================
# IDE files
# ====================================================
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ====================================================
# Build & Distribution
# ====================================================
dist/
build/
lib/
*.tgz

# ====================================================
# Coverage files
# ====================================================
coverage/
.nyc_output/
*.lcov

# ====================================================
# Temporary files
# ====================================================
*.tmp
*.temp
.cache/
.tmp/
.temp/

# ====================================================
# Environment & Config backups
# ====================================================
*.backup
*.bak
*.old
*.orig

# ====================================================
# Database files
# ====================================================
*.sqlite
*.db
*.sql

# ====================================================
# Misc
# ====================================================
*.pid
*.seed
*.pid.lock
.vercel
.now
