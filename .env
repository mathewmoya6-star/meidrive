# =====================================================
# M-PESA ENVIRONMENT
# =====================================================

# Environment: sandbox | production
MPESA_ENVIRONMENT=sandbox

# Test phone numbers (sandbox only)
MPESA_TEST_PHONE=254708374149
MPESA_TEST_PIN=123456

# =====================================================
# CALLBACK URLs (REPLACE WITH YOUR ACTUAL DOMAIN)
# =====================================================

# For production, replace with: https://www.meidriveafrica.com
# For local testing with ngrok: https://your-ngrok-url.ngrok.io

MPESA_CALLBACK_URL=https://your-domain.com/api/mpesa/callback
MPESA_TIMEOUT_URL=https://your-domain.com/api/mpesa/timeout
MPESA_RESULT_URL=https://your-domain.com/api/mpesa/result
MPESA_CONFIRMATION_URL=https://your-domain.com/api/mpesa/confirmation
MPESA_VALIDATION_URL=https://your-domain.com/api/mpesa/validation

# =====================================================
# SERVER CONFIGURATION
# =====================================================

NODE_ENV=development
PORT=3000
HOST=localhost

# =====================================================
# DATABASE (Supabase is primary, these are for local fallback)
# =====================================================

# SQLite (for local development fallback)
DB_STORAGE=./database.sqlite
DB_DIALECT=sqlite

# PostgreSQL (if connecting directly to Supabase DB)
# DB_HOST=db.qpqkmmkrzxlhcpccefjn.supabase.co
# DB_PORT=5432
# DB_NAME=postgres
# DB_USER=postgres
# DB_PASSWORD=your_db_password

# =====================================================
# AUTHENTICATION (Supabase handles this, but JWT for custom needs)
# =====================================================

JWT_SECRET=mei_drive_africa_super_secret_key_change_in_production
JWT_EXPIRES_IN=7d
SESSION_SECRET=mei_drive_africa_session_secret_change_me

# Supabase Auth Settings
SUPABASE_AUTO_CONFIRM_EMAIL=true
SUPABASE_SITE_URL=http://localhost:3000

# =====================================================
# STORAGE (Supabase Storage)
# =====================================================

# Supabase Storage Buckets
SUPABASE_STORAGE_BUCKET_AVATARS=avatars
SUPABASE_STORAGE_BUCKET_DOCUMENTS=documents
SUPABASE_STORAGE_BUCKET_CERTIFICATES=certificates

# Max file sizes (in bytes)
MAX_AVATAR_SIZE=2097152
MAX_DOCUMENT_SIZE=5242880
MAX_CERTIFICATE_SIZE=10485760

# =====================================================
# NTSA API INTEGRATION (For driver license verification)
# =====================================================

NTSA_API_URL=https://api.ntsa.go.ke
NTSA_API_KEY=your_ntsa_api_key
NTSA_API_SECRET=your_ntsa_api_secret
NTSA_ENVIRONMENT=sandbox

# =====================================================
# EMAIL CONFIGURATION (Supabase Auth handles email, but for custom)
# =====================================================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@meidriveafrica.com

# =====================================================
# ADMIN & NOTIFICATIONS
# =====================================================

ADMIN_EMAIL=admin@meidriveafrica.com
ALERT_EMAIL=alerts@meidriveafrica.com
SUPPORT_EMAIL=support@meidriveafrica.com

# =====================================================
# RATE LIMITING
# =====================================================

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# =====================================================
# LOGGING
# =====================================================

LOG_LEVEL=info
LOG_DIR=./logs

# =====================================================
# FEATURE FLAGS
# =====================================================

ENABLE_MPESA=true
ENABLE_MPESA_SANDBOX=true
ENABLE_STK_PUSH=true
ENABLE_C2B=false
ENABLE_B2C=false
ENABLE_REVERSALS=false
ENABLE_NTSA_INTEGRATION=false
ENABLE_OAUTH=false

# =====================================================
# WEBHOOK SECURITY
# =====================================================

MPESA_WEBHOOK_SECRET=your_webhook_secret_key_here
SUPABASE_WEBHOOK_SECRET=your_supabase_webhook_secret

# =====================================================
# CORS CONFIGURATION
# =====================================================

CORS_ORIGIN=http://localhost:3000,http://localhost:8000,https://www.meidriveafrica.com
CORS_CREDENTIALS=true

# =====================================================
# NGROK (for local testing M-Pesa callbacks)
# =====================================================

# NGROK_AUTH_TOKEN=your_ngrok_token
# NGROK_PORT=3000

# =====================================================
# MONITORING & ANALYTICS
# =====================================================

# SENTRY_DSN=your_sentry_dsn
# ANALYTICS_ID=UA-XXXXXXXXX-X

# =====================================================
# BACKUP CONFIGURATION
# =====================================================

BACKUP_ENABLED=false
BACKUP_DIR=./backups
BACKUP_SCHEDULE=0 0 * * *

# =====================================================
# =====================================================
# PRODUCTION OVERRIDES (uncomment in production)
# =====================================================
# NODE_ENV=production
# MPESA_ENVIRONMENT=production
# SUPABASE_AUTO_CONFIRM_EMAIL=false
# MPESA_CALLBACK_URL=https://www.meidriveafrica.com/api/mpesa/callback
# MPESA_TIMEOUT_URL=https://www.meidriveafrica.com/api/mpesa/timeout
# LOG_LEVEL=error
# ENABLE_MPESA_SANDBOX=false
# ENABLE_NTSA_INTEGRATION=true
