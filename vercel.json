{
  "rewrites": [
    { "source": "/admin-dashboard", "destination": "/admin-dashboard.html" },
    { "source": "/reset-password", "destination": "/reset-password.html" },
    { "source": "/update-password", "destination": "/update-password.html" },
    { "source": "/course", "destination": "/course.html" },
    { "source": "/unit", "destination": "/unit.html" },
    { "source": "/quiz-bank", "destination": "/quiz-bank.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}
